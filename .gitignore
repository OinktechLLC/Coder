```gitignore
# Dependencies
node_modules/

# Build artifacts
dist/
build/
*.js.map
*.css.map

# Environment variables
.env
.env.local
*.env.*

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs
*.log

# Coverage
coverage/
htmlcov/
.coverage

# OS generated files
.DS_Store
Thumbs.db

# Vite specific
vite.config.js.timestamp*

# Monaco editor worker files (if any get generated during build)
*.worker.js
```
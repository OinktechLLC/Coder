{
  "name": "coder-pawno",
  "version": "1.0.0",
  "description": "Modern web-based code editor inspired by VSCode and Pawno with Russian language support",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && node server.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "cd server && node server.js"
  },
  "keywords": ["pawno", "vscode", "editor", "compiler", "samp"],
  "author": "Coder-Pawno Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
